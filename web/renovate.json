{
  "extends": ["config:recommended"],
  "schedule": ["at any time"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "lockFileMaintenance"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true
  },
  "prHourlyLimit": 20,
  "prConcurrentLimit": 50
}
