# macOS cruft
.DS_Store
**/.DS_Store

# Claude
.claude/settings.local.json

# Net misc files
net/crates/net/sdk-ts/dist/
net/crates/net/bindings/python/python/net/*.so
net/crates/net/.claude/settings.local.json
net/crates/net/bindings/python/.venv/*

# Node binding TS build artifacts. The hand-written modules
# (errors.ts, mesh_rpc.ts) compile to .js + .d.ts in-place via
# `npm run build:ts`; those outputs ship in the npm tarball but
# don't belong in git. `index.js` / `index.d.ts` are NOT
# generated by tsc — they're emitted by napi-rs from the Rust
# crate — so they stay tracked.
net/crates/net/bindings/node/errors.js
net/crates/net/bindings/node/errors.d.ts
net/crates/net/bindings/node/mesh_rpc.js
net/crates/net/bindings/node/mesh_rpc.d.ts
net/crates/net/bindings/node/dist/
# ignore ALL python source, including new
# binding files that should be tracked in git.
net/crates/net/bindings/python/python/**/*.so
net/crates/net/bindings/python/python/**/*.pyd
net/crates/net/bindings/python/python/**/__pycache__/

# Env variables
.env
.env.*

# Lockfiles
package-lock.json

# Copies of libraries
memex/
l0/
