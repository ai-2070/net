# macOS cruft
.DS_Store
**/.DS_Store

# Claude
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Net misc files
net/crates/net/sdk-ts/dist/
net/crates/net/bindings/python/python/net/*.so
net/crates/net/.claude/settings.local.json
net/crates/net/bindings/python/.venv/*

# Node binding build artifacts. The hand-written modules
# (errors.ts, mesh_rpc.ts, meshdb.ts) compile to .js + .d.ts
# in-place via `npm run build:ts`; `index.js` / `index.d.ts` are
# emitted by napi-rs from the Rust crate. Both kinds ship in the
# npm tarball but don't belong in git — every consumer of source
# regenerates them via the build, and tracked-but-stale copies
# drift against the Rust source on every napi-derive change.
net/crates/net/bindings/node/errors.js
net/crates/net/bindings/node/errors.d.ts
net/crates/net/bindings/node/mesh_rpc.js
net/crates/net/bindings/node/mesh_rpc.d.ts
net/crates/net/bindings/node/index.js
net/crates/net/bindings/node/index.d.ts
net/crates/net/bindings/node/dist/
# ignore ALL python source, including new
# binding files that should be tracked in git.
net/crates/net/bindings/python/python/**/*.so
net/crates/net/bindings/python/python/**/*.pyd
net/crates/net/bindings/python/python/**/__pycache__/

# Python editable-install metadata (created by `pip install -e .`).
net/crates/net/sdk-py/src/*.egg-info/
net/crates/net/sdk-py/**/__pycache__/

# Env variables
.env
.env.*

# Lockfiles
package-lock.json
!web/package-lock.json

# Copies of libraries
memex/
l0/
net/crates/net/deck-*.txt
net/crates/net/bindings/node/meshdb.d.ts
net/crates/net/bindings/node/meshdb.js
net/crates/net/bindings/node/aggregator.d.ts
net/crates/net/bindings/node/aggregator.js
net/crates/net/bindings/node/tool.d.ts
net/crates/net/bindings/node/tool.js

# Flamegraphs
.profiling/
DEBUG_*.md

# Hermes
hermes/
hermes-agent/
.cocoindex_code/
.codegraph/

# OpenClaw
openclaw/
