{
  "name": "@net-mesh/core",
  "version": "0.21.0",
  "description": "High-performance, schema-agnostic event bus for AI runtime workloads",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./errors": {
      "types": "./errors.d.ts",
      "default": "./errors.js"
    },
    "./mesh_rpc": {
      "types": "./mesh_rpc.d.ts",
      "default": "./mesh_rpc.js"
    },
    "./meshdb": {
      "types": "./meshdb.d.ts",
      "default": "./meshdb.js"
    },
    "./aggregator": {
      "types": "./aggregator.d.ts",
      "default": "./aggregator.js"
    }
  },
  "napi": {
    "binaryName": "net",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-2070/net"
  },
  "keywords": [
    "event-bus",
    "high-performance",
    "streaming",
    "ai",
    "llm",
    "rust",
    "napi"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "errors.js",
    "errors.d.ts",
    "mesh_rpc.js",
    "mesh_rpc.d.ts",
    "meshdb.js",
    "meshdb.d.ts",
    "aggregator.js",
    "aggregator.d.ts",
    "*.node"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --features redis,net,cortex,compute,groups,meshos,deck,meshdb,aggregator",
    "build:debug": "napi build --platform --features redis,net,cortex,compute,groups,meshos,deck,meshdb,aggregator",
    "build:test": "napi build --platform --features redis,net,cortex,compute,groups,meshos,deck,meshdb,aggregator,test-helpers",
    "build:ts": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:ts && napi prepublish -t npm",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.json",
    "universal": "napi universal",
    "version": "napi version"
  },
  "engines": {
    "node": ">=20"
  }
}
