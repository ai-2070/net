{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"]
  },
  "include": ["test/**/*.ts", "vitest.config.ts"],
  // `*.bun.ts` benchmarks reference the Bun global; type-check
  // them only with `@types/bun` installed (a Bun-runtime opt-in).
  "exclude": ["node_modules", "test/**/*.bun.ts"]
}
